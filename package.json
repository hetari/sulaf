{
  "name": "sulaf",
  "version": "0.0.0",
  "private": true,
  "author": "Ebraheem Alhetari",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check": "bun fmt && bun lint",
    "fix": "bun fmt && bun lint:fix",
    "prepare": "husky",
    "docs:dev": "bun --filter ./apps/www dev",
    "docs:build": "bun --filter ./apps/www build",
    "docs:preview": "bun --filter ./apps/www preview",
    "docs:generate": "bun --filter ./apps/www generate",
    "registry:build": "bun --filter ./packages/registry build"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nano-staged": "^0.9.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "nano-staged": {
    "*.{js,jsx,ts,tsx,vue}": "bun lint:fix",
    "*.{js,jsx,ts,tsx,vue,json,css,md}": "bun fmt:check"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=24.0.0"
  },
  "packageManager": "bun@1.3.10"
}
