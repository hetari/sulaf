{
  "name": "sulaf",
  "version": "0.0.0",
  "private": true,
  "author": "Ebraheem Alhetari",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check": "bun fmt && bun lint",
    "fix": "bun fmt && bun lint:fix",
    "prepare": "husky",
    "docs:dev": "bun --filter ./apps/www dev",
    "docs:build": "bun --filter ./apps/www build",
    "docs:preview": "bun --filter ./apps/www preview",
    "docs:generate": "bun --filter ./apps/www generate",
    "docs:postinstall": "bun --filter ./apps/www postinstall",
    "registry:build": "bun --filter ./packages/registry build",
    "registry:test": "bun --filter ./packages/registry test"
  },
  "catalog": {
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.577.0",
    "reka-ui": "^2.9.2",
    "tailwind-merge": "^3.5.0",
    "vaul-vue": "^0.4.1",
    "vue": "^3.5.30",
    "vue-sonner": "^2.0.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nano-staged": "^0.9.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "nano-staged": {
    "*": "bun check"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=24.0.0"
  },
  "packageManager": "bun@1.3.10"
}
