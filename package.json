{
  "name": "sulaf",
  "version": "0.0.1",
  "private": true,
  "author": "Ebraheem Alhetari",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check": "bun fmt && bun lint",
    "fix": "bun fmt && bun lint:fix",
    "prepare": "husky",
    "docs:dev": "bun --filter ./apps/www dev",
    "docs:build": "bun --filter ./apps/www build",
    "docs:preview": "bun --filter ./apps/www preview",
    "docs:generate": "bun --filter ./apps/www generate",
    "docs:postinstall": "bun --filter ./apps/www postinstall",
    "playground:dev": "bun --filter ./apps/playground dev",
    "playground:build": "bun --filter ./apps/playground build",
    "playground:preview": "bun --filter ./apps/playground preview",
    "registry:delete": "rm -rf ./apps/www/public/r",
    "registry:build": "bun registry:delete && bun --filter ./packages/registry build && bun check",
    "test": "bun --filter ./packages/registry test",
    "release": "bun scripts/release.ts"
  },
  "catalog": {
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "@vue/compiler-sfc": "^3.5.31",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "npm-run-all2": "^8.0.4",
    "reka-ui": "^2.9.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.0",
    "vaul-vue": "^0.4.1",
    "vue": "^3.5.31",
    "vue-router": "^5.0.3",
    "vue-sonner": "^2.0.9",
    "vue-tsc": "^3.2.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@types/bun": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nano-staged": "^0.9.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "nano-staged": {
    "*": "bun check"
  },
  "packageManager": "bun@latest"
}
