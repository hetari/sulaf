    {
      "path": "default/autocomplete/AutocompleteList.vue",
      "type": "registry:component"
    },
    {
      "path": "default/autocomplete/Autocomplete.vue",
      "type": "registry:component"
    },
    {
      "path": "default/autocomplete/AutocompleteEmpty.vue",
